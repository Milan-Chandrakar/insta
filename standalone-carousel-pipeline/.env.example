#
# Standalone Instagram carousel pipeline environment placeholders
# Copy to: .env
# These values are only read when the matching field is empty in config.json.
#

# -----------------------------
# Private music mode
# -----------------------------
# Required for mode=private_music
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password
INSTAGRAM_SESSION_FILE=./.instagrapi-session.json

# Instagram private location PK used by instagrapi
INSTAGRAM_LOCATION_PK=212988663

# Music search term from Instagram's library
MUSIC_TRACK=Calm Vibes

# -----------------------------
# Official Graph mode
# -----------------------------
# Required for mode=official_graph
GRAPH_IG_USER_ID=YOUR_NUMERIC_INSTAGRAM_BUSINESS_USER_ID
GRAPH_ACCESS_TOKEN=YOUR_LONG_LIVED_GRAPH_ACCESS_TOKEN

# Public hosting for official_graph image uploads
CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
CLOUDINARY_UPLOAD_PRESET=YOUR_UNSIGNED_CLOUDINARY_UPLOAD_PRESET
CLOUDINARY_FOLDER=sanatan-dharma-ai/carousel

# Facebook Page location ID for Graph publishing
LOCATION_ID=YOUR_FACEBOOK_PAGE_LOCATION_ID

# -----------------------------
# Common optional metadata
# -----------------------------
# If omitted in config.json, the default caption file name is caption.txt
CAPTION_FILE_NAME=caption.txt

# Not supported by this standalone pipeline yet.
# If set, the script will abort and tell you to run it from an external scheduler.
SCHEDULE_UTC=2026-05-28T09:00:00Z
